digraph "World"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [id="Node000001",label="World",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip=" "];
  Node2 -> Node1 [id="edge6_Node000001_Node000002",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">config</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node2 [id="Node000002",label="WorldConfig",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structWorldConfig.html",tooltip="Settings and Information on a World and it's data."];
  Node3 -> Node2 [id="edge7_Node000002_Node000003",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">buffer_interval</TD></TR>
<TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">pool_interval</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node3 [id="Node000003",label="Interval",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structInterval.html",tooltip="An interval, generally used for Buffers and Pools."];
  Node4 -> Node1 [id="edge8_Node000001_Node000004",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">object_buffer</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node4 [id="Node000004",label="GameObject",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structGameObject.html",tooltip=" "];
  Node5 -> Node4 [id="edge9_Node000004_Node000005",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">pose</TD></TR>
<TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">previous_pose</TD></TR>
</TABLE>> ,fontcolor="grey" ];
  Node5 [id="Node000005",label="Pose",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structPose.html",tooltip="A position in the World."];
  Node3 -> Node1 [id="edge10_Node000001_Node000003",dir="back",color="darkorchid3",style="dashed",tooltip=" ",label=<<TABLE CELLBORDER="0" BORDER="0"><TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">interval_buffer</TD></TR>
<TR><TD VALIGN="top" ALIGN="LEFT" CELLPADDING="1" CELLSPACING="0">interval_pool</TD></TR>
</TABLE>> ,fontcolor="grey" ];
